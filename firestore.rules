rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER FUNCTIONS ──
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'XJRYpmaBichWwlb3meNQRFwNnxZ2';
    }
    function isActiveDealer() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/evl_ws_dealers/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/evl_ws_dealers/$(request.auth.uid)).data.status == 'active';
    }
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ── RETAIL CUSTOMER COLLECTIONS ──

    // evl_customers — customer owns their record, admin can read all
    match /evl_customers/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // evl_leads — admin only
    match /evl_leads/{docId} {
      allow read, write: if isAdmin();
      allow create: if true; // allow unauthenticated lead capture from forms
    }

    // evl_wholesale_leads — admin only
    match /evl_wholesale_leads/{docId} {
      allow read, write: if isAdmin();
      allow create: if true;
    }

    // evl_consumer_calls — admin only (call log)
    match /evl_consumer_calls/{docId} {
      allow read, write: if isAdmin();
      allow create: if true;
    }

    // evl_mastermind_customers — admin only retail CRM
    match /evl_mastermind_customers/{docId} {
      allow read, write: if isAdmin();
    }

    // evl_activations — $199 platform fee activation records
    // Customer can create their own, admin can read all
    match /evl_activations/{docId} {
      allow create: if true; // allow unauthenticated activation (guest checkout)
      allow read, write: if isAdmin();
      allow read: if request.auth != null &&
        resource.data.uid == request.auth.uid;
    }

    // evl_appointments — appointment notification engine
    // Customer can create AND update (e.g. confirm status), admin can read/write all
    match /evl_appointments/{docId} {
      allow create: if true; // allow any authenticated or guest customer to book
      allow update: if true; // allow guest customer to confirm their own appointment
      allow read, write: if isAdmin();
      allow read: if request.auth != null &&
        resource.data.uid == request.auth.uid;
    }

    // ── WHOLESALE COLLECTIONS ──

    // evl_auctions — public read, admin write, active dealers can bid
    match /evl_auctions/{auctionId} {
      allow read: if true; // public read for auction display
      allow write: if isAdmin();
      allow update: if isActiveDealer(); // dealers can submit bids
    }

    // evl_accident_cards — In Case of Accident dossier, open access (no login required)
    match /evl_accident_cards/{docId} {
      allow read, write: if true;
    }

    // evl_service_ledger — Maintenance Ledger entries, same open email-based access
    // pattern as evl_accident_cards (customer identified by email, not Firebase Auth login)
    match /evl_service_ledger/{docId} {
      allow read, write: if true;
    }

    // evl_vehicle_evaluations — EVL Certified Vehicle Evaluation submissions
    // (VIN decode + condition report + photos + contact info), same open pattern
    match /evl_vehicle_evaluations/{docId} {
      allow read, write: if true;
    }

    // evl_state_licensing — WS Exchange per-state licensing tier reference
    // (green/yellow/red/pending_review). Open for now, same pattern as other
    // reference collections tonight — worth tightening write to isAdmin()
    // once a real admin panel exists for editing this.
    match /evl_state_licensing/{stateCode} {
      allow read, write: if true;
    }

    // evl_state_tax_rules — per-state sales tax rate, trade-in credit eligibility,
    // and flat-cap rules for deal-gap.html and other retail calculators. Open for
    // now, same pattern as other reference collections tonight.
    match /evl_state_tax_rules/{stateCode} {
      allow read, write: if true;
    }

    // evl_ws_dealers — dealer owns their record, admin controls status
    match /evl_ws_dealers/{dealerId} {
      allow read: if isAdmin() || isActiveDealer();
      allow create: if true; // allow new dealer registration
      allow update: if isAdmin() || isOwner(dealerId);
    }

    // ── AFTERMARKET NETWORK COLLECTIONS ──

    // evl_aftermarket_shops — public read so customers can browse the certified directory,
    // admin-only write (records are created via the admin approval flow, not directly)
    match /evl_aftermarket_shops/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // evl_aftermarket_referrals — logged when a customer taps "Get Contact Info" on a shop card
    match /evl_aftermarket_referrals/{docId} {
      allow create: if true; // allow unauthenticated referral logging
      allow read, update, delete: if isAdmin();
    }

    // evl_aftermarket_applications — submitted by shops via the public application form
    match /evl_aftermarket_applications/{docId} {
      allow create: if true; // allow unauthenticated shop application submission
      allow read, update, delete: if isAdmin();
    }

    // evl_email_suppression — CAN-SPAM unsubscribe list. Written by unsubscribe.html
    // (guest, no login) and read by lib/emailCompliance.js before every customer/dealer
    // email via a raw REST call (also unauthenticated). Doc ID is the email address,
    // so read/create must both be open the same way the other guest-facing
    // collections above are.
    match /evl_email_suppression/{docId} {
      allow read, create: if true;
      allow update, delete: if isAdmin();
    }

  }
}
