{
  "routes": [
    {
      "src": "/api/decode",
      "dest": "/api/decode"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html",
      "headers": {
        "X-Frame-Options": "ALLOWALL",
        "Content-Security-Policy": "frame-ancestors *",
        "Access-Control-Allow-Origin": "*"
      }
    }
  ]
}